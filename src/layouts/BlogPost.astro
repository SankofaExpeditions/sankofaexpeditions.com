---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  jsonLd?: object[];
}

const { post, jsonLd } = Astro.props;
const { title, description, publishDate, updatedDate, author, category, tags, readTime } = post.data;

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const formattedUpdate = updatedDate ? new Date(updatedDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
}) : null;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- Article Hero -->
  <section class="article-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li aria-current="page">{title}</li>
        </ol>
      </nav>
      <div class="article-meta-top">
        <span class="article-category">{category}</span>
        {readTime && <span class="article-read-time">{readTime}</span>}
      </div>
      <h1>{title}</h1>
      <p class="article-subtitle">{description}</p>
      <div class="article-byline">
        <span class="article-author">By {author}</span>
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
        {formattedUpdate && (
          <span class="article-updated">Updated {formattedUpdate}</span>
        )}
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="article-content section">
    <div class="container container--narrow">
      <div class="prose">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <footer class="article-footer">
          <div class="article-tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </footer>
      )}
    </div>
  </article>

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container container--narrow text-center">
      <h2>Get More Intel Like This</h2>
      <hr class="divider" />
      <p>Join our list for exclusive intelligence drops, country deep-dives, diaspora opportunities, visa updates, and on-the-ground dispatches from across Africa.</p>
      <div style="margin-top: var(--space-xl); display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap;">
        <a href="/#join" class="btn btn--white">Subscribe for Updates</a>
        <a href="/contact" class="btn btn--outline-white">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .article-hero {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding: var(--space-3xl) 0 var(--space-4xl);
  }

  .breadcrumb {
    margin-bottom: var(--space-xl);
  }

  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    list-style: none;
    font-size: 0.85rem;
    flex-wrap: wrap;
  }

  .breadcrumb li + li::before {
    content: '/';
    color: rgba(255, 255, 255, 0.25);
    margin-right: var(--space-sm);
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.5);
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: #fff;
  }

  .breadcrumb [aria-current="page"] {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8rem;
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .article-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
    padding: 4px 12px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 100px;
  }

  .article-read-time {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .article-hero h1 {
    color: #fff;
    margin-bottom: var(--space-md);
    max-width: 22ch;
  }

  .article-subtitle {
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 60ch;
    margin-bottom: var(--space-xl);
  }

  .article-byline {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .article-author {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
  }

  .article-updated {
    font-style: italic;
  }

  /* Prose. Markdown content styling */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--color-text);
  }

  .prose :global(h2) {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h3) {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose :global(h4) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
    max-width: none;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .prose :global(li) {
    margin-bottom: var(--space-sm);
  }

  .prose :global(blockquote) {
    margin: var(--space-2xl) 0;
    padding: var(--space-lg) var(--space-xl);
    border-left: 3px solid var(--color-dark);
    background: var(--color-bg-alt);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-text);
  }

  .prose :global(table) {
    width: 100%;
    margin: var(--space-xl) 0;
    border-collapse: collapse;
    font-size: 0.9375rem;
    overflow-x: auto;
    display: block;
  }

  .prose :global(thead) {
    background: var(--color-dark);
    color: #fff;
  }

  .prose :global(th) {
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .prose :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(tbody tr:hover) {
    background: var(--color-bg-alt);
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--color-dark);
  }

  .prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-3xl) 0;
  }

  /* Article Footer */
  .article-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 4px 12px;
    background: var(--color-bg-alt);
    border-radius: 100px;
    color: var(--color-text-muted);
  }
</style>
