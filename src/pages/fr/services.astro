---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/index';

const lang = 'fr';
const title = 'Services & Tarification';
const description = 'Les niveaux de services de renseignement de Sankofa Expeditions — des Briefings Intelligence pays unique aux Expéditions Sur Mesure complètes. Recherche de terrain, renseignement vérifié et rapports actionnables pour la diaspora africaine.';

const tiers = [
  {
    name: 'Briefing Intelligence',
    slug: 'intelligence-brief',
    tagline: 'Recherche mono-pays pour des objectifs ciblés',
    description: 'Un rapport de renseignement concis et actionnable couvrant un pays et un objectif principal — idéal pour les membres de la diaspora explorant une destination de relocalisation, un marché d\'investissement ou une connexion patrimoniale spécifique.',
    highlights: [
      'Focus sur un seul pays',
      'Un objectif de recherche principal',
      'Données de terrain vérifiées',
      'Livraison sous 2 semaines',
      'Rapport numérique (PDF + interactif)',
      'Un cycle de questions-réponses',
    ],
    cta: 'Demander un Briefing',
    featured: false,
  },
  {
    name: 'Package Reconnaissance',
    slug: 'reconnaissance-package',
    tagline: 'Analyse multi-pays approfondie pour les décideurs',
    description: 'Un package de renseignement complet couvrant plusieurs pays ou objectifs — conçu pour les membres de la diaspora comparant des destinations, explorant des opportunités d\'affaires régionales ou planifiant des voyages patrimoniaux multi-étapes.',
    highlights: [
      'Jusqu\'à 3 pays comparés',
      'Objectifs de recherche multiples',
      'Analyse comparative & scoring',
      'Interviews de sources sur le terrain',
      'Livraison sous 4 semaines',
      'Rapport détaillé + résumé exécutif',
      'Deux cycles de consultation de suivi',
      'Mises à jour trimestrielles (6 mois)',
    ],
    cta: 'Obtenir une Proposition',
    featured: true,
  },
  {
    name: 'Expédition Sur Mesure',
    slug: 'custom-expedition',
    tagline: 'Service complet pour les missions complexes',
    description: 'Un engagement de renseignement sur mesure adapté à vos besoins exacts — de la reconnaissance d\'affaires multi-nations aux expéditions patrimoniales de groupe, en passant par la due diligence d\'investissement ou la logistique de relocalisation continentale.',
    highlights: [
      'Périmètre pays illimité',
      'Brief de recherche entièrement personnalisé',
      'Analyste de renseignement dédié',
      'Visites de reconnaissance sur le terrain',
      'Vérification de partenaires et fournisseurs',
      'Cartographie légale et réglementaire',
      'Mandat de conseil continu',
      'Réponse et planification prioritaires',
      'Option de briefing en personne',
    ],
    cta: 'Démarrer une Conversation',
    featured: false,
  },
];

const comparisonFeatures = [
  { feature: 'Périmètre pays', brief: '1 pays', recon: 'Jusqu\'à 3 pays', custom: 'Illimité' },
  { feature: 'Objectifs de recherche', brief: '1 principal', recon: 'Multiples', custom: 'Sur mesure' },
  { feature: 'Sources sur le terrain', brief: '✓', recon: '✓', custom: '✓' },
  { feature: 'Interviews de sources', brief: '—', recon: '✓', custom: '✓' },
  { feature: 'Analyse comparative', brief: '—', recon: '✓', custom: '✓' },
  { feature: 'Visites de reconnaissance', brief: '—', recon: '—', custom: '✓' },
  { feature: 'Vérification partenaires', brief: '—', recon: 'Basique', custom: 'Complète' },
  { feature: 'Cartographie légale', brief: 'Aperçu', recon: 'Détaillée', custom: 'Cartographie complète' },
  { feature: 'Délai de livraison', brief: '~2 semaines', recon: '~4 semaines', custom: 'Sur mesure' },
  { feature: 'Consultation de suivi', brief: '1 cycle', recon: '2 cycles', custom: 'Mandat continu' },
  { feature: 'Mises à jour trimestrielles', brief: '—', recon: '6 mois', custom: '12 mois' },
  { feature: 'Analyste dédié', brief: '—', recon: '—', custom: '✓' },
  { feature: 'Briefing en personne', brief: '—', recon: '—', custom: '✓' },
];

const faqItems = [
  {
    question: 'Combien coûtent vos services ?',
    answer: 'La tarification dépend du périmètre, de la profondeur et du nombre de pays concernés. Nous ne publions pas de prix fixes car chaque engagement est personnalisé. Un Briefing Intelligence pour un pays sera très différent d\'un Package Reconnaissance multi-nations. Contactez-nous avec vos objectifs et nous vous fournirons une proposition détaillée sous 48 heures — sans engagement.',
  },
  {
    question: 'Quelle est la différence entre un Briefing et un Package Reconnaissance ?',
    answer: 'Un Briefing Intelligence se concentre sur un seul pays et un objectif principal — c\'est un instantané ciblé. Un Package Reconnaissance couvre jusqu\'à trois pays avec analyse comparative, interviews de sources et mises à jour continues. Pensez au Briefing comme une frappe chirurgicale ; le Package Reconnaissance est une campagne complète.',
  },
  {
    question: 'Comment recueillez-vous vos renseignements ?',
    answer: 'Notre intelligence provient de sources vérifiées sur le terrain à travers l\'Afrique — de vraies personnes dans de vrais lieux. Nous combinons réseaux de sources locales, données officielles, reconnaissance de première main et interviews d\'experts. Nous ne recyclons pas d\'articles de blog et ne récupérons pas de bases de données obsolètes. Chaque donnée est actuelle et vérifiée.',
  },
  {
    question: 'Puis-je passer d\'un niveau à un autre ?',
    answer: 'Absolument. De nombreux clients commencent par un Briefing Intelligence et passent à un Package Reconnaissance ou une Expédition Sur Mesure au fur et à mesure que leurs projets se développent. Nous appliquons votre investissement initial au niveau supérieur — aucune dépense perdue.',
  },
  {
    question: 'Proposez-vous des tarifs de groupe ou organisationnels ?',
    answer: 'Oui. Nous travaillons avec des organisations de la diaspora, des clubs d\'investissement, des groupes religieux et des équipes d\'entreprise. Les engagements de groupe sont structurés comme des Expéditions Sur Mesure avec des coûts partagés et des livrables adaptés. Contactez-nous pour discuter des besoins de votre groupe.',
  },
  {
    question: 'Quels pays couvrez-vous ?',
    answer: 'Les 54 nations africaines. Notre réseau de renseignement couvre l\'ensemble du continent — des pôles établis de la diaspora comme le Ghana, le Kenya et l\'Afrique du Sud aux destinations émergentes comme le Rwanda, le Sénégal et la Tanzanie. Aucun pays n\'est exclu.',
  },
  {
    question: 'Combien de temps faut-il pour recevoir mon rapport ?',
    answer: 'Les Briefings Intelligence sont généralement livrés sous 2 semaines. Les Packages Reconnaissance prennent environ 4 semaines. Les Expéditions Sur Mesure suivent un calendrier que nous établissons ensemble en fonction du périmètre et de la complexité. Une livraison accélérée est disponible pour les engagements urgents.',
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://sankofaexpeditions.com/fr/services#webpage",
    "url": "https://sankofaexpeditions.com/fr/services",
    "name": title,
    "description": description,
    "isPartOf": { "@id": "https://sankofaexpeditions.com/#website" },
    "about": { "@id": "https://sankofaexpeditions.com/#organization" },
    "inLanguage": "fr-FR",
    "datePublished": "2024-01-01",
    "dateModified": new Date().toISOString().split('T')[0]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t('nav.home', lang), "item": "https://sankofaexpeditions.com/fr" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://sankofaexpeditions.com/fr/services" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://sankofaexpeditions.com/fr/services#service",
    "serviceType": "Services de Renseignement & Recherche",
    "provider": { "@id": "https://sankofaexpeditions.com/#organization" },
    "name": "Services de Renseignement Sankofa Expeditions",
    "description": "Services de renseignement et d'expédition pour la diaspora africaine — couvrant relocalisation, affaires, patrimoine, investissement et renseignement sur mesure à travers les 54 nations africaines.",
    "areaServed": { "@type": "Place", "name": "Afrique" },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Niveaux de Services de Renseignement",
      "itemListElement": tiers.map((tier, index) => ({
        "@type": "Offer",
        "name": tier.name,
        "description": tier.description,
        "position": index + 1,
        "itemOffered": {
          "@type": "Service",
          "name": tier.name,
          "description": tier.description,
          "provider": { "@id": "https://sankofaexpeditions.com/#organization" }
        }
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://sankofaexpeditions.com/fr/services#faq",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalURL="https://sankofaexpeditions.com/fr/services"
  jsonLd={jsonLd}
  lang="fr"
>

  <!-- Hero Banner -->
  <section class="svc-hero" aria-labelledby="svc-hero-heading">
    <div class="container svc-hero-inner">
      <span class="eyebrow">Services de Renseignement</span>
      <h1 id="svc-hero-heading">Services & Tarification</h1>
      <p class="svc-hero-description">
        Chaque engagement est adapté à vos objectifs. Choisissez le niveau de renseignement qui correspond à votre mission — des briefings pays ciblés aux expéditions complètes à travers le continent.
      </p>
      <nav class="svc-hero-breadcrumb" aria-label="Fil d'Ariane">
        <ol>
          <li><a href="/fr">{t('nav.home', lang)}</a></li>
          <li aria-current="page">Services</li>
        </ol>
      </nav>
    </div>
  </section>

  <!-- Service Tiers -->
  <section class="section" aria-labelledby="tiers-heading">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Choisissez Votre Niveau</span>
        <h2 id="tiers-heading">Niveaux de Services de Renseignement</h2>
        <p>Trois niveaux de profondeur — chacun soutenu par du renseignement vérifié sur le terrain à travers l'Afrique.</p>
      </div>
      <div class="svc-tiers">
        {tiers.map((tier) => (
          <article class={`card svc-tier-card ${tier.featured ? 'svc-tier-card--featured' : ''}`} id={tier.slug}>
            {tier.featured && <div class="svc-tier-badge">Le Plus Populaire</div>}
            <div class="svc-tier-header">
              <h3 class="svc-tier-name">{tier.name}</h3>
              <p class="svc-tier-tagline">{tier.tagline}</p>
            </div>
            <div class="svc-tier-price">
              <span class="svc-tier-price-label">Contactez-nous pour les tarifs</span>
              <span class="svc-tier-price-note">Adapté à vos objectifs</span>
            </div>
            <p class="svc-tier-desc">{tier.description}</p>
            <ul class="svc-tier-features" role="list">
              {tier.highlights.map((item) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href="/fr/contact" class={`btn ${tier.featured ? 'btn--primary' : 'btn--secondary'} svc-tier-cta`}>
              {tier.cta}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section section--alt" aria-labelledby="compare-heading">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Côte à Côte</span>
        <h2 id="compare-heading">Comparer les Niveaux de Service</h2>
        <p>Voyez exactement ce qui est inclus à chaque niveau d'engagement.</p>
      </div>
      <div class="svc-table-wrapper">
        <table class="svc-table" role="table">
          <thead>
            <tr>
              <th scope="col">Fonctionnalité</th>
              <th scope="col">Briefing Intelligence</th>
              <th scope="col" class="svc-table-featured">Package Reconnaissance</th>
              <th scope="col">Expédition Sur Mesure</th>
            </tr>
          </thead>
          <tbody>
            {comparisonFeatures.map((row) => (
              <tr>
                <td class="svc-table-feature">{row.feature}</td>
                <td>{row.brief}</td>
                <td class="svc-table-featured">{row.recon}</td>
                <td>{row.custom}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--dark" aria-labelledby="process-heading">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Le Processus</span>
        <h2 id="process-heading">Comment Ça Marche</h2>
        <p>Du premier contact au renseignement actionnable — simple, direct, sans perte de temps.</p>
      </div>
      <div class="svc-process">
        <div class="svc-process-step">
          <div class="svc-process-number" aria-hidden="true">01</div>
          <h3>Partagez Votre Objectif</h3>
          <p>Dites-nous ce que vous souhaitez accomplir — relocalisation, affaires, patrimoine, investissement ou quelque chose d'unique. Nous écoutons d'abord.</p>
        </div>
        <div class="svc-process-step">
          <div class="svc-process-number" aria-hidden="true">02</div>
          <h3>Recevez Votre Proposition</h3>
          <p>Sous 48 heures, nous livrons une proposition personnalisée avec périmètre, calendrier et tarification — pas de packages génériques, sans engagement.</p>
        </div>
        <div class="svc-process-step">
          <div class="svc-process-number" aria-hidden="true">03</div>
          <h3>Nous Déployons le Renseignement</h3>
          <p>Notre réseau de terrain s'active. Nous recherchons, vérifions, interviewons les sources et compilons votre rapport de renseignement.</p>
        </div>
        <div class="svc-process-step">
          <div class="svc-process-number" aria-hidden="true">04</div>
          <h3>Vous Agissez en Confiance</h3>
          <p>Armé de renseignement vérifié — pas d'articles de blog ni de brochures touristiques — vous exécutez votre plan en position de connaissance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container container--narrow">
      <div class="section-header">
        <span class="eyebrow">FAQ</span>
        <h2 id="faq-heading">Questions Fréquemment Posées</h2>
        <p>Réponses aux questions courantes sur nos services, tarifs et processus.</p>
      </div>
      <dl class="faq-list" role="list">
        {faqItems.map((item) => (
          <details class="faq-item card" name="faq">
            <summary class="faq-item__question" role="listitem">
              <h3>{item.question}</h3>
              <svg class="faq-item__chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div class="faq-item__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark svc-cta-section" aria-labelledby="cta-heading">
    <div class="container text-center">
      <span class="eyebrow">Commencez</span>
      <h2 id="cta-heading">Prêt à Agir avec Intelligence ?</h2>
      <hr class="divider" />
      <p class="svc-cta-description">
        Partagez votre objectif et nous vous recommanderons le bon niveau — ou créerons quelque chose d'entièrement sur mesure. Chaque engagement commence par une conversation, pas par une carte de crédit.
      </p>
      <div class="svc-cta-actions">
        <a href="/fr/contact" class="btn btn--primary">
          Contactez-Nous
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/fr/expeditions" class="btn btn--secondary">Voir les Expéditions</a>
      </div>
      <p class="svc-cta-email">
        Ou écrivez-nous directement : <a href="mailto:info@sankofaexpeditions.com"><strong>info@sankofaexpeditions.com</strong></a>
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ================================
     Services Page Styles (FR)
     ================================ */

  .svc-hero {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding: var(--space-3xl) 0 var(--space-3xl);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .svc-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(196, 132, 29, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 20%, rgba(196, 132, 29, 0.04) 0%, transparent 50%);
    pointer-events: none;
  }

  .svc-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .svc-hero .eyebrow { margin-bottom: var(--space-lg); }

  .svc-hero h1 {
    color: var(--color-text-light);
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .svc-hero-description {
    font-size: 1.15rem;
    color: var(--color-text-on-dark);
    opacity: 0.85;
    max-width: 600px;
    margin: 0 auto var(--space-xl);
    line-height: 1.7;
  }

  .svc-hero-breadcrumb ol {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.85rem;
  }

  .svc-hero-breadcrumb li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-on-dark);
    opacity: 0.6;
  }

  .svc-hero-breadcrumb li + li::before {
    content: '→';
    color: var(--color-gold);
    opacity: 0.5;
  }

  .svc-hero-breadcrumb a {
    color: var(--color-gold-light);
    text-decoration: none;
    opacity: 1;
  }

  .svc-hero-breadcrumb a:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }

  .svc-hero-breadcrumb li[aria-current="page"] {
    color: var(--color-text-on-dark);
    opacity: 0.8;
  }

  .svc-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: stretch;
  }

  @media (min-width: 960px) {
    .svc-tiers {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .svc-tier-card {
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .svc-tier-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .svc-tier-card--featured {
    border-color: var(--color-dark);
    border-width: 2px;
    box-shadow: var(--shadow-md);
  }

  .svc-tier-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--color-dark);
    color: var(--color-text-light);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 1rem;
    border-radius: 0 0 0 var(--radius-md);
  }

  .svc-tier-header { margin-bottom: var(--space-lg); }

  .svc-tier-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-dark);
    margin: 0 0 var(--space-xs);
  }

  .svc-tier-tagline {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 100%;
  }

  .svc-tier-price {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-md) 0;
    margin-bottom: var(--space-md);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .svc-tier-price-label {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-dark);
  }

  .svc-tier-price-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .svc-tier-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    max-width: 100%;
  }

  .svc-tier-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex-grow: 1;
  }

  .svc-tier-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .svc-tier-features svg {
    flex-shrink: 0;
    color: var(--color-dark);
    margin-top: 2px;
  }

  .svc-tier-card--featured .svc-tier-features svg {
    color: var(--color-gold);
  }

  .svc-tier-cta {
    width: 100%;
    margin-top: auto;
  }

  .svc-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .svc-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .svc-table thead {
    background: var(--color-dark);
    color: var(--color-text-light);
  }

  .svc-table th {
    padding: var(--space-md) var(--space-lg);
    text-align: left;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .svc-table td {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
