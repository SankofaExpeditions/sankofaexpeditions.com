---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLocalizedPath } from '../../i18n/index';

const lang = 'fr';
const title = t('nav.contact', lang) + ' — Sankofa Expeditions';
const description = 'Contactez Sankofa Expeditions. Que vous planifiiez une relocalisation, du scouting d\'affaires ou des voyages patrimoniaux en Afrique.';

const faqItems = [
  {
    question: 'Do you operate as a travel agency?',
    answer: 'No. Sankofa Expeditions is an intelligence platform, not a traditional travel agency. We provide deep research, on-the-ground reconnaissance, and structured intelligence reports.'
  },
  {
    question: 'Which African countries do you cover?',
    answer: 'All 54 African nations. Our intelligence network spans the entire continent.'
  },
  {
    question: 'How much does your intelligence service cost?',
    answer: 'Pricing varies by scope and depth. Reach out through the form above and we\'ll provide a detailed proposal within 48 hours.'
  },
  {
    question: 'Can I join a group expedition?',
    answer: 'Yes! We run curated group experiences throughout the year — immersive expeditions designed for diaspora members. Follow us on social media or join our mailing list.'
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": "https://sankofaexpeditions.com/fr/contact/#contactpage",
    "url": "https://sankofaexpeditions.com/fr/contact",
    "name": title,
    "description": description,
    "isPartOf": { "@id": "https://sankofaexpeditions.com/#website" },
    "about": { "@id": "https://sankofaexpeditions.com/#organization" },
    "inLanguage": "fr-FR",
    "datePublished": "2024-01-01",
    "dateModified": new Date().toISOString().split('T')[0]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t('nav.home', lang), "item": "https://sankofaexpeditions.com/fr" },
      { "@type": "ListItem", "position": 2, "name": t('nav.contact', lang), "item": "https://sankofaexpeditions.com/fr/contact" }
    ]
  }
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} lang="fr">
  <!-- Hero Banner -->
  <section class="contact-hero section--dark" aria-labelledby="contact-hero-heading">
    <div class="container text-center">
      <span class="eyebrow">{t('nav.contact', lang)}</span>
      <h1 id="contact-hero-heading">Get in Touch</h1>
      <p class="contact-hero__subtitle">
        We're here to help you navigate your next move across the African continent.
      </p>
    </div>
  </section>

  <!-- Contact Intro + Form + Sidebar -->
  <section class="section contact-section" aria-labelledby="contact-form-heading">
    <div class="container">
      <div class="contact-intro text-center">
        <h2 id="contact-form-heading">Let's Start a Conversation</h2>
        <hr class="divider" />
        <p class="contact-intro__text">
          Whether you're planning a relocation, scouting business opportunities, or just want to learn more — we want to hear from you.
        </p>
      </div>

      <div class="contact-grid">
        <div class="contact-form-wrapper card">
          <form class="contact-form" method="POST" action="/contact" name="contact" aria-label="Contact form">
            <div class="form-group">
              <label for="contact-name">Full Name <span aria-hidden="true">*</span></label>
              <input type="text" id="contact-name" name="name" required autocomplete="name" placeholder="Your full name" />
            </div>
            <div class="form-group">
              <label for="contact-email">Email Address <span aria-hidden="true">*</span></label>
              <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label for="contact-subject">Subject <span aria-hidden="true">*</span></label>
              <select id="contact-subject" name="subject" required>
                <option value="" disabled selected>Select a topic...</option>
                <option value="general">General Inquiry</option>
                <option value="relocation">Relocation Intelligence</option>
                <option value="business">Business Reconnaissance</option>
                <option value="heritage">Heritage Journey</option>
                <option value="investment">Investment Scouting</option>
                <option value="partnership">Partnership</option>
                <option value="media">Media / Press</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contact-message">Message <span aria-hidden="true">*</span></label>
              <textarea id="contact-message" name="message" required rows="6" placeholder="Tell us about your goals, questions, or how we can help..."></textarea>
            </div>
            <button type="submit" class="btn btn--primary contact-form__submit">
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
          </form>
        </div>

        <aside class="contact-sidebar" aria-label="Contact information">
          <div class="contact-info-card card">
            <h3>Direct Contact</h3>
            <div class="contact-detail">
              <div class="contact-detail__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <strong>Email</strong>
                <a href="mailto:expeditsankofa@gmail.com">expeditsankofa@gmail.com</a>
              </div>
            </div>
            <hr class="contact-sidebar__divider" />
            <div class="response-note">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              <p>We typically respond within <strong>24–48 hours</strong>.</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section section--alt contact-faq" aria-labelledby="faq-heading">
    <div class="container container--narrow">
      <div class="section-header">
        <span class="eyebrow">FAQ</span>
        <h2 id="faq-heading">Frequently Asked Questions</h2>
        <p>Quick answers to the questions we hear most often.</p>
      </div>
      <dl class="faq-list" role="list">
        {faqItems.map((item) => (
          <details class="faq-item card" name="faq">
            <summary class="faq-item__question" role="listitem">
              <h3>{item.question}</h3>
              <svg class="faq-item__chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </summary>
            <div class="faq-item__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </dl>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero { padding: var(--space-4xl) 0 var(--space-3xl); text-align: center; }
  .contact-hero h1 { color: var(--color-text-light); margin-top: var(--space-sm); margin-bottom: var(--space-md); }
  .contact-hero__subtitle { color: var(--color-text-on-dark); opacity: 0.85; font-size: 1.125rem; max-width: 50ch; margin: 0 auto; }

  .contact-intro { margin-bottom: var(--space-3xl); }
  .contact-intro__text { font-size: 1.125rem; color: var(--color-text-muted); max-width: 65ch; margin: 0 auto; }

  .contact-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); align-items: start; }
  @media (min-width: 768px) { .contact-grid { grid-template-columns: 1.5fr 1fr; } }

  .contact-form { display: flex; flex-direction: column; gap: var(--space-lg); }
  .form-group { display: flex; flex-direction: column; gap: var(--space-xs); }
  .form-group label { font-weight: 600; font-size: 0.9375rem; color: var(--color-dark); }
  .form-group label span { color: var(--color-accent-red); }
  .form-group select { width: 100%; padding: 0.875rem 1rem; font-family: var(--font-sans); font-size: 1rem; color: var(--color-text); background: var(--color-surface); border: 2px solid var(--color-border); border-radius: var(--radius-sm); outline: none; cursor: pointer; appearance: none; }
  .form-group select:focus { border-color: var(--color-gold); box-shadow: 0 0 0 3px rgba(196, 132, 29, 0.1); }
  .form-group textarea { resize: vertical; min-height: 140px; }
  .contact-form__submit { align-self: flex-start; width: 100%; }
  @media (min-width: 480px) { .contact-form__submit { width: auto; } }

  .contact-info-card { position: sticky; top: calc(var(--header-height) + var(--space-xl)); }
  .contact-info-card h3 { font-size: 1.25rem; margin-bottom: var(--space-lg); }
  .contact-detail { display: flex; align-items: flex-start; gap: var(--space-md); }
  .contact-detail__icon { flex-shrink: 0; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: var(--color-bg-alt); border-radius: var(--radius-sm); color: var(--color-gold); }
  .contact-detail strong { display: block; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); margin-bottom: 2px; }
  .contact-detail a { font-weight: 500; word-break: break-all; }
  .contact-sidebar__divider { border: none; border-top: 1px solid var(--color-border); margin: var(--space-lg) 0; }

  .response-note { display: flex; align-items: flex-start; gap: var(--space-sm); padding: var(--space-md); background: linear-gradient(135deg, rgba(196, 132, 29, 0.06), rgba(196, 132, 29, 0.02)); border-left: 3px solid var(--color-gold); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
  .response-note svg { flex-shrink: 0; color: var(--color-gold); margin-top: 2px; }
  .response-note p { font-size: 0.9375rem; color: var(--color-text-muted); margin: 0; }

  .faq-list { display: flex; flex-direction: column; gap: var(--space-md); }
  .faq-item { cursor: pointer; transition: all var(--transition-base); overflow: hidden; }
  .faq-item:hover { border-color: var(--color-gold); transform: none; }
  .faq-item__question { display: flex; align-items: center; justify-content: space-between; gap: var(--space-md); list-style: none; user-select: none; }
  .faq-item__question::-webkit-details-marker { display: none; }
  .faq-item__question h3 { font-size: 1.0625rem; font-weight: 600; margin: 0; flex: 1; }
  .faq-item__chevron { flex-shrink: 0; color: var(--color-text-muted); transition: transform var(--transition-base); }
  .faq-item[open] .faq-item__chevron { transform: rotate(180deg); color: var(--color-gold); }
  .faq-item__answer { padding-top: var(--space-md); border-top: 1px solid var(--color-border); margin-top: var(--space-md); }
  .faq-item__answer p { color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.8; margin: 0; }
</style>
