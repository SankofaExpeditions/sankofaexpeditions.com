---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { t } from '../../i18n/index';

const lang = 'fr';
const title = `${t('travel.packages.title', lang)} | Sankofa Expeditions`;
const description = t('travel.meta.desc', lang);

const packages = [
  { slug: 'heritage', icon: '🏛️', titleKey: 'travel.heritage.title', descKey: 'travel.heritage.desc', priceKey: 'travel.heritage.price' },
  { slug: 'relocation', icon: '🏠', titleKey: 'travel.relocation.title', descKey: 'travel.relocation.desc', priceKey: 'travel.relocation.price' },
  { slug: 'business', icon: '💼', titleKey: 'travel.business.title', descKey: 'travel.business.desc', priceKey: 'travel.business.price' },
  { slug: 'investment', icon: '📈', titleKey: 'travel.investment.title', descKey: 'travel.investment.desc', priceKey: 'travel.investment.price' },
  { slug: 'groups', icon: '👥', titleKey: 'travel.groups.title', descKey: 'travel.groups.desc', priceKey: 'travel.groups.price' },
  { slug: 'safari', icon: '🦁', titleKey: 'travel.safari.title', descKey: 'travel.safari.desc', priceKey: 'travel.safari.price' },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sankofaexpeditions.com" },
    { "@type": "ListItem", "position": 2, "name": t('nav.travel', lang), "item": `https://sankofaexpeditions.com/fr/travel` }
  ]
};

const travelAgencyJsonLd = {
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  "@id": "https://sankofaexpeditions.com/#travelagency",
  "name": "Sankofa Expeditions",
  "url": `https://sankofaexpeditions.com/fr/travel`,
  "description": t('travel.meta.desc', lang),
  "telephone": "+1-702-389-4202",
  "priceRange": "$2,000 - $15,000+"
};

const jsonLd = [breadcrumbJsonLd, travelAgencyJsonLd];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} lang={lang}>
  <section class="travel-hero" aria-labelledby="travel-hero-title">
    <div class="container">
      <h1 id="travel-hero-title">{t('travel.hero.headline', lang)}</h1>
      <p class="hero-sub">{t('travel.hero.subheadline', lang)}</p>
      <div class="hero-ctas">
        <a href="#packages" class="btn btn-primary">{t('travel.hero.cta.explore', lang)}</a>
        <a href="/fr/quote" class="btn btn-secondary">{t('travel.hero.cta.quote', lang)}</a>
      </div>
    </div>
  </section>

  <section id="packages" class="travel-packages" aria-labelledby="packages-title">
    <div class="container">
      <h2 id="packages-title">{t('travel.packages.title', lang)}</h2>
      <div class="package-grid">
        {packages.map((pkg) => (
          <article class="package-card" aria-labelledby={`pkg-${pkg.slug}`}>
            <span class="package-icon" aria-hidden="true">{pkg.icon}</span>
            <h3 id={`pkg-${pkg.slug}`}>{t(pkg.titleKey, lang)}</h3>
            <p class="package-desc">{t(pkg.descKey, lang)}</p>
            <p class="package-price">{t(pkg.priceKey, lang)}</p>
            <div class="package-ctas">
              <a href={`/fr/travel/${pkg.slug}`} class="btn btn-outline">{t('travel.learnmore', lang)}</a>
              <a href={`/fr/quote?pkg=${pkg.slug}`} class="btn btn-primary-sm">{t('travel.getquote', lang)}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="trust-bar" aria-label="Accreditation">
    <div class="container">
      <p>{t('travel.trust.licensed', lang)} &middot; IATAN &middot; CLIA &middot; ASTA</p>
      <p>{t('travel.trust.powered', lang)} &middot; Est. 1998</p>
      <p>{t('travel.trust.serving', lang)}</p>
    </div>
  </section>

  <section class="not-sure" aria-labelledby="not-sure-title">
    <div class="container">
      <h2 id="not-sure-title">{t('travel.notsure.title', lang)}</h2>
      <p>{t('travel.notsure.desc', lang)}</p>
      <a href="/fr/consult" class="btn btn-primary">{t('travel.notsure.cta', lang)}</a>
    </div>
  </section>

  <EmailCapture lang={lang} />
</BaseLayout>

<style>
  .travel-hero { padding: 6rem 0 4rem; text-align: center; background: var(--color-dark, #111); border-bottom: 1px solid rgba(255,255,255,0.1); }
  .travel-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 600; margin-bottom: 1rem; color: #fff; }
  .hero-sub { font-size: 1.15rem; max-width: 700px; margin: 0 auto 2rem; color: rgba(255,255,255,0.75); line-height: 1.7; }
  .hero-ctas { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn { display: inline-block; padding: 0.85rem 2rem; text-decoration: none; font-weight: 600; font-size: 0.95rem; border-radius: 2px; transition: all 0.2s; }
  .btn-primary { background: #fff; color: #111; }
  .btn-primary:hover { background: #e0e0e0; }
  .btn-secondary { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.4); }
  .btn-secondary:hover { border-color: #fff; }
  .travel-packages { padding: 5rem 0; }
  .travel-packages h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 4vw, 2.5rem); text-align: center; margin-bottom: 3rem; color: #fff; }
  .package-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2rem; max-width: 1100px; margin: 0 auto; }
  .package-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); padding: 2rem; text-align: center; transition: border-color 0.2s; }
  .package-card:hover { border-color: rgba(255,255,255,0.3); }
  .package-icon { font-size: 2.5rem; display: block; margin-bottom: 1rem; }
  .package-card h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; margin-bottom: 0.75rem; color: #fff; }
  .package-desc { color: rgba(255,255,255,0.65); font-size: 0.95rem; line-height: 1.6; margin-bottom: 1rem; }
  .package-price { font-weight: 700; color: #fff; font-size: 1.1rem; margin-bottom: 1.5rem; }
  .package-ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn-outline { padding: 0.6rem 1.2rem; border: 1px solid rgba(255,255,255,0.3); color: #fff; font-size: 0.85rem; text-decoration: none; font-weight: 500; }
  .btn-outline:hover { border-color: #fff; }
  .btn-primary-sm { padding: 0.6rem 1.2rem; background: #fff; color: #111; font-size: 0.85rem; text-decoration: none; font-weight: 600; }
  .btn-primary-sm:hover { background: #e0e0e0; }
  .trust-bar { padding: 3rem 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); }
  .trust-bar p { color: rgba(255,255,255,0.5); font-size: 0.9rem; margin: 0.3rem 0; }
  .not-sure { padding: 5rem 0; text-align: center; }
  .not-sure h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.6rem, 3.5vw, 2.2rem); color: #fff; margin-bottom: 1rem; }
  .not-sure p { color: rgba(255,255,255,0.7); max-width: 600px; margin: 0 auto 2rem; line-height: 1.7; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  @media (max-width: 768px) { .package-grid { grid-template-columns: 1fr; } .travel-hero { padding: 4rem 0 3rem; } }
</style>
