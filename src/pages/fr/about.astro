---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLocalizedPath } from '../../i18n/index';

const lang = 'fr';
const title = t('nav.about', lang) + ' — Sankofa Expeditions';
const description = 'Sankofa Expeditions est une plateforme d\'intelligence créée par la diaspora, pour la diaspora. Nous fournissons du renseignement vérifié et de terrain sur l\'Afrique.';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": "https://sankofaexpeditions.com/fr/about/#aboutpage",
    "url": "https://sankofaexpeditions.com/fr/about",
    "name": title,
    "description": description,
    "isPartOf": {
      "@id": "https://sankofaexpeditions.com/#website"
    },
    "about": {
      "@id": "https://sankofaexpeditions.com/#organization"
    },
    "mainEntity": {
      "@id": "https://sankofaexpeditions.com/#organization"
    },
    "inLanguage": "fr-FR",
    "datePublished": "2024-01-01",
    "dateModified": new Date().toISOString().split('T')[0]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": t('nav.home', lang),
        "item": "https://sankofaexpeditions.com/fr"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": t('nav.about', lang),
        "item": "https://sankofaexpeditions.com/fr/about"
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} ogType="website" jsonLd={jsonLd} lang="fr">

  <!-- Hero Banner -->
  <section class="about-hero" aria-labelledby="about-heading">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href={getLocalizedPath('/', lang)}>{t('nav.home', lang)}</a></li>
          <li aria-current="page">{t('nav.about', lang)}</li>
        </ol>
      </nav>
      <span class="eyebrow">Who We Are</span>
      <h1 id="about-heading">
        About Sankofa Expeditions®
      </h1>
      <p class="about-hero__subtitle">
        We're not a travel agency. We're the intelligence platform the African diaspora has been waiting for.
      </p>
    </div>
  </section>

  <!-- The Origin Story -->
  <article class="section" aria-labelledby="origin-heading">
    <div class="container container--narrow">
      <header class="section-header">
        <span class="eyebrow">The Origin Story</span>
        <h2 id="origin-heading">Why Sankofa Expeditions Exists</h2>
        <hr class="divider" />
      </header>
      <div class="prose">
        <p>
          The diaspora's relationship with Africa is broken. Not by distance, not by time — by information gaps, gatekeepers, and tourist traps. For too long, the African diaspora has been fed a diet of curated highlights, surface-level travel content, and overpriced "heritage tours" that barely scratch the surface of what the continent actually offers.
        </p>
        <p>
          Sankofa Expeditions was born to fix that.
        </p>
        <p>
          Founded by someone who lived the diaspora experience and saw firsthand that the biggest barrier to meaningful engagement with Africa wasn't money or desire — <strong>it was intelligence</strong>. Real, verified, on-the-ground intelligence about how things actually work.
        </p>
        <p>
          We built Sankofa because we got tired of watching people get burned by bad information, exploited by middlemen, and disillusioned by experiences that didn't match the marketing. The diaspora deserves better. Africa deserves better. This is our answer.
        </p>
      </div>
    </div>
  </article>

  <!-- The Name -->
  <section class="section section--alt" aria-labelledby="name-heading">
    <div class="container container--narrow">
      <header class="section-header">
        <span class="eyebrow">The Name</span>
        <h2 id="name-heading">What Sankofa Means</h2>
        <hr class="divider" />
      </header>
      <div class="sankofa-meaning">
        <div class="sankofa-symbol" aria-hidden="true">
          <img src="/logo-black.png" alt="" width="140" height="140" style="border-radius: 50%; opacity: 0.9;" />
        </div>
        <div class="prose">
          <p>
            <strong>Sankofa</strong> is an Akan concept from Ghana. The Sankofa bird flies forward while looking backward — carrying an egg in its mouth, a symbol of the future nurtured by wisdom from the past.
          </p>
          <blockquote>
            <p>"Se wo were fi na wosankofa a yenkyi"</p>
            <cite>— It is not wrong to go back for that which you have forgotten.</cite>
          </blockquote>
          <p>
            We go back to Africa not with nostalgia but with purpose. Not as tourists but as people reclaiming a connection that was severed, armed with intelligence and intent.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="section" aria-labelledby="difference-heading">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">What Makes Us Different</span>
        <h2 id="difference-heading">Intelligence, Not Itineraries</h2>
        <hr class="divider" />
        <p>We're not a travel agency. We're an intelligence platform. There's a difference.</p>
      </header>
      <div class="grid grid--3">
        <div class="card difference-card">
          <div class="difference-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 20H6a2 2 0 01-2-2V6a2 2 0 012-2h12a2 2 0 012 2v4" />
              <path d="M15 2v4" /><path d="M9 2v4" /><path d="M4 10h16" />
              <circle cx="18" cy="18" r="3" /><path d="M20.2 20.2L22 22" />
            </svg>
          </div>
          <h3>Travel Agencies Sell Packages</h3>
          <p>Pre-packaged tours with markup, middlemen, and zero transparency.</p>
          <div class="difference-vs">
            <span class="eyebrow">We deliver intelligence</span>
            <p>Deep-dive country profiles, real cost breakdowns, visa navigation, and ground-truth reporting.</p>
          </div>
        </div>
        <div class="card difference-card">
          <div class="difference-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 10l5-5" /><path d="M20 5h-5v5" />
              <rect x="3" y="3" width="7" height="7" rx="1" />
              <rect x="14" y="14" width="7" height="7" rx="1" />
              <path d="M3 14l5 5" /><path d="M3 19h5v-5" />
            </svg>
          </div>
          <h3>Tourism Sites Show Highlights</h3>
          <p>Glossy photos, best-case scenarios, and SEO-optimized listicles.</p>
          <div class="difference-vs">
            <span class="eyebrow">We show reality</span>
            <p>What it actually costs, what the infrastructure looks like, and what nobody puts in the brochure.</p>
          </div>
        </div>
        <div class="card difference-card">
          <div class="difference-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 113 3L7 19l-4 1 1-4L16.5 3.5z" />
            </svg>
          </div>
          <h3>Blogs Share Opinions</h3>
          <p>Personal anecdotes and hot takes from a two-week trip. Useful for vibes, useless for decisions.</p>
          <div class="difference-vs">
            <span class="eyebrow">We verify facts on the ground</span>
            <p>On-the-ground networks across Africa feeding us verified, current intelligence.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" aria-labelledby="about-cta-heading">
    <div class="container container--narrow text-center">
      <header class="section-header">
        <span class="eyebrow">{t('capture.eyebrow', lang)}</span>
        <h2 id="about-cta-heading">Ready to Move with Intelligence?</h2>
        <hr class="divider" />
        <p>
          The diaspora is waking up. Africa is calling. But you don't answer that call with blind faith — you answer it with intelligence.
        </p>
      </header>
      <div class="about-cta-actions">
        <a href={getLocalizedPath('/', lang) + '#join'} class="btn btn--primary">{t('hero.cta.primary', lang)} →</a>
        <a href={getLocalizedPath('/', lang)} class="btn btn--secondary">{t('nav.home', lang)}</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .about-hero {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding: var(--space-3xl) 0 var(--space-4xl);
    position: relative;
    overflow: hidden;
  }

  .about-hero .container { position: relative; z-index: 1; }
  .breadcrumb { margin-bottom: var(--space-xl); }
  .breadcrumb ol { display: flex; align-items: center; gap: var(--space-sm); list-style: none; font-size: 0.85rem; }
  .breadcrumb li { display: flex; align-items: center; gap: var(--space-sm); }
  .breadcrumb li + li::before { content: '/'; color: rgba(255, 255, 255, 0.3); }
  .breadcrumb a { color: rgba(255, 255, 255, 0.5); text-decoration: none; transition: color var(--transition-fast); }
  .breadcrumb a:hover { color: #fff; }
  .breadcrumb [aria-current="page"] { color: rgba(255, 255, 255, 0.6); }
  .about-hero .eyebrow { margin-bottom: var(--space-md); }
  .about-hero h1 { color: var(--color-text-light); margin-bottom: var(--space-lg); max-width: 700px; }
  .about-hero__subtitle { font-size: 1.2rem; color: var(--color-text-on-dark); opacity: 0.85; max-width: 600px; line-height: 1.7; }

  .prose { max-width: 70ch; margin: 0 auto; }
  .prose p { font-size: 1.08rem; line-height: 1.8; color: var(--color-text); margin-bottom: var(--space-lg); }
  .prose strong { color: var(--color-dark); font-weight: 600; }

  .sankofa-meaning { display: flex; flex-direction: column; align-items: center; gap: var(--space-2xl); }
  @media (min-width: 768px) { .sankofa-meaning { flex-direction: row; align-items: flex-start; } }
  .sankofa-symbol { flex-shrink: 0; opacity: 0.9; }

  blockquote { border-left: 3px solid var(--color-gold); padding-left: var(--space-lg); margin: var(--space-xl) 0; }
  blockquote p { font-size: 1.15rem !important; font-style: italic; color: var(--color-dark) !important; font-weight: 500; margin-bottom: var(--space-sm) !important; }
  blockquote cite { font-size: 0.9rem; color: var(--color-text-muted); font-style: normal; }

  .difference-card { display: flex; flex-direction: column; gap: var(--space-md); padding: var(--space-xl) var(--space-lg); }
  .difference-icon { color: var(--color-gold); width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: rgba(196, 132, 29, 0.08); border-radius: var(--radius-sm); }
  .difference-card h3 { font-size: 1.15rem; margin: 0; }
  .difference-card > p { font-size: 0.95rem; color: var(--color-text-muted); margin: 0; line-height: 1.65; }
  .difference-vs { margin-top: auto; padding-top: var(--space-md); border-top: 1px solid var(--color-border); }
  .difference-vs .eyebrow { margin-bottom: var(--space-xs); }
  .difference-vs p { font-size: 0.92rem; line-height: 1.65; color: var(--color-text); margin: 0; }

  .about-cta-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-md); margin-top: var(--space-xl); }
</style>
