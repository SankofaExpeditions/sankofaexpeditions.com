---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = 'The Sankofa Journal';
const description = 'Intelligence drops, country deep-dives, and diaspora pathways. Real data from the ground — not opinions, not travel brochures.';

// Get all blog posts sorted by date (newest first)
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "https://sankofaexpeditions.com/blog/#collectionpage",
    "url": "https://sankofaexpeditions.com/blog",
    "name": title,
    "description": description,
    "isPartOf": { "@id": "https://sankofaexpeditions.com/#website" },
    "about": { "@id": "https://sankofaexpeditions.com/#organization" },
    "inLanguage": "en-US",
    "datePublished": "2024-01-01",
    "dateModified": new Date().toISOString().split('T')[0]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": "https://sankofaexpeditions.com/blog/#breadcrumb",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sankofaexpeditions.com" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://sankofaexpeditions.com/blog" }
    ]
  }
];
---

<BaseLayout title={title} description={description} ogType="website" jsonLd={jsonLd}>
  <!-- Hero Banner -->
  <section class="blog-hero" aria-labelledby="blog-heading">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li aria-current="page">Blog</li>
        </ol>
      </nav>
      <span class="eyebrow">Intel Drops & Deep Dives</span>
      <h1 id="blog-heading">The Sankofa Journal</h1>
      <p class="blog-hero__subtitle">
        Intelligence from the ground — country profiles, visa guides, diaspora pathways, and real data for Africans and the African diaspora.
      </p>
    </div>
  </section>

  {posts.length > 0 ? (
    <!-- Published Articles -->
    <section class="section" aria-labelledby="articles-heading">
      <div class="container">
        <div class="articles-grid">
          {posts.map((post) => (
            <article class="article-card card">
              <a href={`/blog/${post.id}`} class="article-card__link">
                <div class="article-card__content">
                  <div class="article-card__meta">
                    <span class="article-card__category">{post.data.category}</span>
                    {post.data.readTime && <span class="article-card__read-time">{post.data.readTime}</span>}
                  </div>
                  <h2 class="article-card__title">{post.data.title}</h2>
                  <p class="article-card__excerpt">{post.data.description}</p>
                  <div class="article-card__footer">
                    <time datetime={post.data.publishDate.toISOString()}>
                      {new Date(post.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <span class="article-card__arrow">Read →</span>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <!-- Coming Soon State -->
    <section class="section" aria-labelledby="coming-heading">
      <div class="container container--narrow text-center">
        <h2 id="coming-heading">First Intel Drops Coming Soon</h2>
        <hr class="divider" />
        <p>We're finalizing our first wave of deep-dive intelligence articles. Subscribe below to get notified when we publish.</p>
      </div>
    </section>
  )}

  <!-- Subscribe CTA -->
  <section class="section section--dark" aria-labelledby="subscribe-heading">
    <div class="container container--narrow text-center">
      <header class="section-header">
        <span class="eyebrow" style="color: rgba(255, 255, 255, 0.5);">Stay Informed</span>
        <h2 id="subscribe-heading">Don't Miss an Intel Drop</h2>
        <hr class="divider" />
        <p>Be the first to receive country deep-dives, diaspora pathway updates, and on-the-ground intelligence. No spam — pure signal.</p>
      </header>
      <div class="subscribe-actions">
        <a href="/#join" class="btn btn--white">Subscribe for Updates →</a>
        <a href="/" class="btn btn--outline-white">Back to Home</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding: var(--space-3xl) 0 var(--space-4xl);
  }

  .breadcrumb { margin-bottom: var(--space-xl); }
  .breadcrumb ol { display: flex; align-items: center; gap: var(--space-sm); list-style: none; font-size: 0.85rem; }
  .breadcrumb li + li::before { content: '/'; color: rgba(255, 255, 255, 0.25); margin-right: var(--space-sm); }
  .breadcrumb a { color: rgba(255, 255, 255, 0.5); }
  .breadcrumb a:hover { color: #fff; }
  .breadcrumb [aria-current="page"] { color: rgba(255, 255, 255, 0.4); }

  .blog-hero h1 { color: #fff; margin-bottom: var(--space-lg); }
  .blog-hero__subtitle { font-size: 1.15rem; color: rgba(255, 255, 255, 0.65); max-width: 55ch; line-height: 1.7; }

  /* Articles Grid */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .articles-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .article-card { padding: 0; overflow: hidden; }
  .article-card__link { display: block; text-decoration: none; color: inherit; }
  .article-card__content { padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-sm); min-height: 260px; }

  .article-card__meta { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
  .article-card__category {
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }
  .article-card__read-time { font-size: 0.75rem; color: var(--color-text-muted); }

  .article-card__title { font-size: 1.2rem; margin: var(--space-xs) 0; line-height: 1.3; }
  .article-card__excerpt { font-size: 0.9rem; line-height: 1.65; color: var(--color-text-muted); flex: 1; }

  .article-card__footer {
    display: flex; justify-content: space-between; align-items: center;
    padding-top: var(--space-md); border-top: 1px solid var(--color-border); margin-top: var(--space-md);
    font-size: 0.8rem; color: var(--color-text-muted);
  }
  .article-card__arrow { font-weight: 600; color: var(--color-dark); }

  .subscribe-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-md); margin-top: var(--space-xl); }
</style>
