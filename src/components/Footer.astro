---
import { t, getLangFromUrl, getLocalizedPath } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;

const currentYear = new Date().getFullYear();

const footerNav = [
  { label: t('nav.home', lang), href: getLocalizedPath('/', lang) },
  { label: t('nav.about', lang), href: getLocalizedPath('/about', lang) },
  { label: t('nav.expeditions', lang), href: getLocalizedPath('/expeditions', lang) },
  { label: t('nav.services', lang), href: getLocalizedPath('/services', lang) },
  { label: t('nav.blog', lang), href: getLocalizedPath('/blog', lang) },
  { label: t('nav.contact', lang), href: getLocalizedPath('/contact', lang) },
];

const socialLinks = [
  { label: 'X (Twitter)', href: 'https://x.com/ExpeditSankofa', icon: 'x' },
  { label: 'Instagram', href: 'https://instagram.com/expeditsankofa', icon: 'instagram' },
  { label: 'TikTok', href: 'https://tiktok.com/@expeditsankofa', icon: 'tiktok' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/sankofaexpeditions', icon: 'linkedin' },
  { label: 'Email', href: 'mailto:expeditsankofa@gmail.com', icon: 'email' },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href={getLocalizedPath('/', lang)} class="footer-logo" aria-label="Sankofa Expeditions®. Home">
          <img src="/logo-header.svg" alt="Sankofa Expeditions logo" class="footer-logo-icon" width="36" height="36" />
          <span class="footer-logo-text">Sankofa Expeditions<sup>®</sup></span>
        </a>
        <p class="footer-tagline">
          {t('footer.tagline', lang)}
        </p>
        <p class="footer-tagline footer-tagline--motto">
          <em>{t('footer.motto', lang)}</em>
        </p>
      </div>

      <!-- Navigation Column -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <h3 class="footer-heading">{t('footer.navigate', lang)}</h3>
        <ul role="list">
          {footerNav.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <!-- Connect Column -->
      <div class="footer-connect">
        <h3 class="footer-heading">{t('footer.connect', lang)}</h3>
        <div class="footer-contact-info">
          <a href="tel:+17023894202" class="footer-phone">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            (702) 389-4202
          </a>
          <a href="mailto:expeditsankofa@gmail.com" class="footer-email">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            expeditsankofa@gmail.com
          </a>
        </div>
        <ul class="social-links" role="list">
          {socialLinks.map(link => (
            <li>
              <a href={link.href} target={link.icon !== 'email' ? '_blank' : undefined} rel={link.icon !== 'email' ? 'noopener noreferrer' : undefined} aria-label={`Follow us on ${link.label}`}>
                {link.icon === 'x' && (
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {link.icon === 'instagram' && (
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                )}
                {link.icon === 'tiktok' && (
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                    <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13a8.28 8.28 0 005.58 2.17V11.7a4.83 4.83 0 01-3.77-1.24V6.69h3.77z"/>
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {link.icon === 'email' && (
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                    <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p>{t('footer.copyright', lang)}</p>
      <p class="footer-motto">
        <em>{t('footer.proverb', lang)}</em>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    margin-bottom: var(--space-2xl);
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  /* Brand */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    margin-bottom: var(--space-md);
  }

  .footer-logo-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    border-radius: 0;
  }

  .footer-logo-text {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text-light);
  }

  .footer-logo-text sup {
    font-size: 0.5em;
    vertical-align: super;
    opacity: 0.85;
  }

  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    max-width: 40ch;
  }

  .footer-tagline--motto {
    margin-top: var(--space-sm);
    font-family: var(--font-serif);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
  }

  /* Navigation */
  .footer-heading {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-lg);
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-nav a {
    color: var(--color-text-on-dark);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
    display: inline-block;
    padding: var(--space-sm) 0;
    min-height: 44px;
    line-height: 1.6;
  }

  .footer-nav a:hover {
    color: #FFFFFF;
  }

  /* Connect */
  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .footer-phone,
  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-on-dark);
    font-size: 0.85rem;
    transition: color var(--transition-fast);
    min-height: 44px;
  }

  .footer-phone:hover,
  .footer-email:hover {
    color: #FFFFFF;
  }

  .social-links {
    list-style: none;
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.1);
    transition: all var(--transition-fast);
  }

  .social-links a:hover {
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.12);
  }

  /* Bottom Bar */
  .footer-bottom {
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 auto;
  }

  .footer-motto {
    font-family: var(--font-serif);
    margin-top: var(--space-sm) !important;
    font-size: 0.75rem !important;
    color: rgba(255, 255, 255, 0.8) !important;
  }
</style>
