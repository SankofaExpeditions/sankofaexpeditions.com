---
---

<section id="join" class="section section--dark" aria-labelledby="join-heading">
  <div class="container container--narrow">
    <div class="cta-box">
      <header class="section-header">
        <span class="eyebrow" style="color: var(--color-gold-light);">Join the Movement</span>
        <h2 id="join-heading">Get the Intel Before Everyone Else</h2>
        <p>
          Join our list for exclusive intelligence drops: country deep-dives, diaspora opportunities, visa updates, investment signals, and on-the-ground dispatches from across Africa. No spam. Pure signal.
        </p>
      </header>

      <form class="signup-form" action="#" method="POST" aria-label="Email newsletter signup">
        <div class="form-row">
          <label for="signup-name" class="sr-only">Your first name</label>
          <input
            type="text"
            id="signup-name"
            name="name"
            placeholder="First name"
            autocomplete="given-name"
            required
          />
          <label for="signup-email" class="sr-only">Your email address</label>
          <input
            type="email"
            id="signup-email"
            name="email"
            placeholder="Your best email"
            autocomplete="email"
            required
          />
          <button type="submit" class="btn btn--primary">Get Intel →</button>
        </div>
        <p class="form-note">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
            <path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2a1.5 1.5 0 110 3 1.5 1.5 0 010-3zm2 9H6v-1h1V7.5H6v-1h3V11h1v1z"/>
          </svg>
          No spam, ever. Unsubscribe anytime. We respect your inbox like we respect the mission.
        </p>
      </form>

      <div class="social-cta">
        <p>Follow the movement:</p>
        <div class="social-buttons">
          <a href="https://x.com/ExpeditSankofa" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Follow on X">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            @ExpeditSankofa
          </a>
          <a href="https://instagram.com/expeditsankofa" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Follow on Instagram">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            @expeditsankofa
          </a>
          <a href="https://tiktok.com/@expeditsankofa" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Follow on TikTok">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13a8.28 8.28 0 005.58 2.17V11.7a4.83 4.83 0 01-3.77-1.24V6.69h3.77z"/></svg>
            @expeditsankofa
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-box {
    text-align: center;
  }

  .signup-form {
    max-width: 640px;
    margin: 0 auto var(--space-2xl);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  @media (min-width: 640px) {
    .form-row {
      flex-direction: row;
    }
  }

  .signup-form input {
    flex: 1;
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--color-text-light);
  }

  .signup-form input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .signup-form input:focus {
    border-color: var(--color-gold);
    background: rgba(255, 255, 255, 0.08);
  }

  .signup-form .btn {
    white-space: nowrap;
    flex-shrink: 0;
  }

  .form-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    font-size: 0.8rem;
    color: var(--color-text-on-dark);
    opacity: 0.5;
  }

  /* Social CTA */
  .social-cta {
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .social-cta p {
    font-size: 0.85rem;
    color: var(--color-text-on-dark);
    opacity: 0.6;
    margin-bottom: var(--space-md);
  }

  .social-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-on-dark);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .social-btn:hover {
    background: rgba(196, 132, 29, 0.12);
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
</style>
