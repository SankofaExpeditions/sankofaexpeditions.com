---
import { t, getLangFromUrl } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;
---

<section id="join" class="section section--dark email-capture" aria-labelledby="capture-heading">
  <div class="container container--narrow text-center">
    <header class="section-header">
      <span class="eyebrow">{t('capture.eyebrow', lang)}</span>
      <h2 id="capture-heading">{t('capture.title', lang)}</h2>
      <hr class="divider" />
      <p>{t('capture.desc', lang)}</p>
    </header>

    <!-- Beehiiv Embedded Subscribe Form -->
    <div class="capture-beehiiv">
      <script async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="85da9e62-26fc-4ac2-8db2-907c54e23299"></script>
    </div>

    <div class="capture-social">
      <a href="https://x.com/ExpeditSankofa" target="_blank" rel="noopener noreferrer" aria-label="Follow on X">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://instagram.com/expeditsankofa" target="_blank" rel="noopener noreferrer" aria-label="Follow on Instagram">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://tiktok.com/@expeditsankofa" target="_blank" rel="noopener noreferrer" aria-label="Follow on TikTok">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13a8.28 8.28 0 005.58 2.17V11.7a4.83 4.83 0 01-3.77-1.24V6.69h3.77z"/></svg>
      </a>
    </div>

    <p class="capture-privacy">{t('capture.privacy', lang)}</p>
  </div>
</section>

<!-- Beehiiv Attribution Tracking -->
<script type="text/javascript" async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>

<style>
  .email-capture {
    padding: var(--space-4xl) 0;
  }

  .capture-beehiiv {
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
    min-height: 120px;
  }

  .capture-social {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .capture-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.06);
    transition: all var(--transition-fast);
  }

  .capture-social a:hover {
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.12);
  }

  .capture-privacy {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 auto;
  }
</style>
