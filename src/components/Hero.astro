---
import { t, getLangFromUrl, getLocalizedPath } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero-grid">
    <div class="hero-content">
      <p class="hero-eyebrow">{t('hero.eyebrow', lang)}</p>
      <h1 id="hero-heading">{t('hero.title', lang)}</h1>
      <p class="hero-description">
        {t('hero.description', lang)}
      </p>
      <div class="hero-actions">
        <a href={getLocalizedPath('/contact', lang)} class="btn btn--white">{t('hero.cta.primary', lang)}</a>
        <a href={getLocalizedPath('/about', lang)} class="btn btn--outline-white">{t('hero.cta.secondary', lang)}</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">54</span>
          <span class="stat-label">{t('hero.stat.nations', lang)}</span>
        </div>
        <div class="stat">
          <span class="stat-number">1000+</span>
          <span class="stat-label">{t('hero.stat.diaspora', lang)}</span>
        </div>
        <div class="stat">
          <span class="stat-number">24/7</span>
          <span class="stat-label">{t('hero.stat.intel', lang)}</span>
        </div>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img src="/logo-white.png" alt="" class="hero-logo-mark" width="280" height="280" />
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding: var(--space-4xl) 0;
    position: relative;
    overflow: hidden;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse at 75% 50%, rgba(255, 255, 255, 0.02) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: 1.3fr 0.7fr;
    }
  }

  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: var(--space-lg);
  }

  .hero h1 {
    color: #FFFFFF;
    margin-bottom: var(--space-lg);
    max-width: 18ch;
  }

  .hero-description {
    font-size: 1.125rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.85);
    max-width: 55ch;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 500;
  }

  /* Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-logo-mark {
    width: 280px;
    height: auto;
    opacity: 0.12;
    filter: grayscale(100%);
  }

  @media (max-width: 959px) {
    .hero-visual {
      display: none;
    }

    .hero {
      min-height: auto;
      padding: var(--space-3xl) 0;
    }
  }
</style>
