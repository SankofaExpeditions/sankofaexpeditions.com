---
import { getLangFromUrl } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;

const offerings = [
  {
    title: 'Travel Intelligence',
    description: 'On-the-ground intel that goes beyond tourist guides, real costs, safety protocols, transportation, housing, and cultural context.',
    highlights: ['Visa & entry requirements', 'Cost-of-living breakdowns', 'Safety & health intelligence', 'Local transport & logistics'],
  },
  {
    title: 'Diaspora Pathways',
    description: 'Real routes for return, reconnection, and building. Not hypotheticals, tested pathways from people who have done it.',
    highlights: ['Relocation roadmaps', 'Dual citizenship guidance', 'Heritage reconnection', 'Community integration'],
  },
  {
    title: 'On-the-Ground Infrastructure',
    description: 'Verified networks of lawyers, realtors, business partners, and service providers across the continent.',
    highlights: ['Vetted local partners', 'Legal & real estate networks', 'Banking & finance guidance', 'Business setup support'],
  },
  {
    title: 'Community & Network',
    description: 'Connect with diaspora members who have already made the move, built the business, or walked the path you\'re considering.',
    highlights: ['Diaspora community access', 'Mentorship connections', 'Group expeditions', 'Ongoing support network'],
  },
];
---

<section class="section section--alt" aria-labelledby="offerings-heading">
  <div class="container">
    <header class="section-header">
      <span class="eyebrow">What We Deliver</span>
      <h2 id="offerings-heading">Intelligence Meets Infrastructure</h2>
      <hr class="divider" />
      <p>Four pillars of real-world support for the African diaspora.</p>
    </header>

    <div class="offerings-grid">
      {offerings.map((offering) => (
        <article class="offering-card card">
          <h3 class="offering-title">{offering.title}</h3>
          <p class="offering-desc">{offering.description}</p>
          <ul class="offering-highlights" role="list">
            {offering.highlights.map(h => (
              <li>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {h}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .offerings-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .offerings-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .offering-card {
    cursor: default;
    border-color: var(--color-border);
  }

  .offering-card:hover {
    border-color: var(--color-dark);
  }

  .offering-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .offering-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .offering-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .offering-highlights li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .offering-highlights svg {
    flex-shrink: 0;
    color: var(--color-dark);
  }
</style>
