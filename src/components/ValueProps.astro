---
import { getLangFromUrl, t } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;

const offerings = [
  {
    title: t('vp.travel.title', lang),
    description: t('vp.travel.desc', lang),
    highlights: [t('vp.travel.h1', lang), t('vp.travel.h2', lang), t('vp.travel.h3', lang), t('vp.travel.h4', lang)],
  },
  {
    title: t('vp.diaspora.title', lang),
    description: t('vp.diaspora.desc', lang),
    highlights: [t('vp.diaspora.h1', lang), t('vp.diaspora.h2', lang), t('vp.diaspora.h3', lang), t('vp.diaspora.h4', lang)],
  },
  {
    title: t('vp.infra.title', lang),
    description: t('vp.infra.desc', lang),
    highlights: [t('vp.infra.h1', lang), t('vp.infra.h2', lang), t('vp.infra.h3', lang), t('vp.infra.h4', lang)],
  },
  {
    title: t('vp.community.title', lang),
    description: t('vp.community.desc', lang),
    highlights: [t('vp.community.h1', lang), t('vp.community.h2', lang), t('vp.community.h3', lang), t('vp.community.h4', lang)],
  },
];
---

<section class="section section--alt" aria-labelledby="offerings-heading">
  <div class="container">
    <header class="section-header">
      <span class="eyebrow">{t('vp.eyebrow', lang)}</span>
      <h2 id="offerings-heading">{t('vp.title', lang)}</h2>
      <hr class="divider" />
      <p>{t('vp.subtitle', lang)}</p>
    </header>

    <div class="offerings-grid">
      {offerings.map((offering) => (
        <article class="offering-card card">
          <h3 class="offering-title">{offering.title}</h3>
          <p class="offering-desc">{offering.description}</p>
          <ul class="offering-highlights" role="list">
            {offering.highlights.map(h => (
              <li>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {h}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .offerings-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 640px) {
    .offerings-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .offering-card {
    cursor: default;
    border-color: var(--color-border);
  }

  .offering-card:hover {
    border-color: var(--color-dark);
  }

  .offering-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .offering-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .offering-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .offering-highlights li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 500;
  }

  .offering-highlights svg {
    flex-shrink: 0;
    color: var(--color-dark);
  }
</style>
