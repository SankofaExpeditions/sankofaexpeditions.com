---
const offerings = [
  {
    icon: 'compass',
    title: 'Travel Intelligence',
    description: 'Deep-dive country profiles, visa navigation, safety intel, cost-of-living data, and cultural briefings that go far beyond what any guidebook offers. Real information for real decisions.',
    highlights: ['Country deep-dives', 'Visa strategy', 'Safety & security intel', 'Cost-of-living analysis'],
  },
  {
    icon: 'path',
    title: 'Diaspora Pathways',
    description: 'Structured programs for reconnection, relocation, and return. From heritage trips to long-term residency planning, we map the path from intention to boots on the ground.',
    highlights: ['Heritage reconnection', 'Relocation planning', 'Citizenship pathways', 'Cultural immersion'],
  },
  {
    icon: 'building',
    title: 'On-the-Ground Infrastructure',
    description: 'Local contacts, vetted service providers, real estate connections, legal partners, and business facilitation. The network you need but can\'t Google.',
    highlights: ['Vetted local network', 'Real estate access', 'Legal & business support', 'Ground transportation'],
  },
  {
    icon: 'community',
    title: 'Community & Network',
    description: 'Join a growing network of diaspora builders, investors, and explorers. Share intelligence, find collaborators, and build alongside people who understand the mission.',
    highlights: ['Builder network', 'Investment circles', 'Shared intelligence', 'Collaborative expeditions'],
  },
];
---

<section id="offerings" class="section" aria-labelledby="offerings-heading">
  <div class="container">
    <header class="section-header">
      <span class="eyebrow">What We Deliver</span>
      <h2 id="offerings-heading">Intelligence Meets Infrastructure</h2>
      <p>Four pillars of real value for Africans and the African diaspora ready to move, build, and thrive.</p>
    </header>

    <div class="offerings-grid grid grid--4">
      {offerings.map((item) => (
        <article class="offering-card card">
          <div class="offering-icon" aria-hidden="true">
            {item.icon === 'compass' && (
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>
              </svg>
            )}
            {item.icon === 'path' && (
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8a2 2 0 100-4 2 2 0 000 4zM6 20a2 2 0 100-4 2 2 0 000 4z"/>
                <path d="M18 8c0 6-12 4-12 12"/>
              </svg>
            )}
            {item.icon === 'building' && (
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="2" width="16" height="20" rx="1"/>
                <path d="M9 22V12h6v10M8 6h.01M16 6h.01M12 6h.01M8 10h.01M16 10h.01M12 10h.01"/>
              </svg>
            )}
            {item.icon === 'community' && (
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
              </svg>
            )}
          </div>
          <h3 class="offering-title">{item.title}</h3>
          <p class="offering-desc">{item.description}</p>
          <ul class="offering-highlights" role="list">
            {item.highlights.map((h) => (
              <li>
                <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                  <path fill="#C4841D" d="M8 0a8 8 0 110 16A8 8 0 018 0zm3.41 5.59a.5.5 0 00-.7 0L7 9.3 5.29 7.59a.5.5 0 00-.7.7l2 2a.5.5 0 00.7 0l4.12-4.12a.5.5 0 000-.58z"/>
                </svg>
                {h}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .offerings-grid {
    gap: var(--space-lg);
  }

  .offering-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl) var(--space-lg);
    text-align: left;
  }

  .offering-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(196, 132, 29, 0.1), rgba(232, 168, 73, 0.06));
    border-radius: var(--radius-md);
    color: var(--color-gold);
    margin-bottom: var(--space-lg);
  }

  .offering-title {
    font-size: 1.15rem;
    margin-bottom: var(--space-sm);
    color: var(--color-dark);
  }

  .offering-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .offering-highlights {
    list-style: none;
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .offering-highlights li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
    font-weight: 500;
  }

  @media (max-width: 959px) {
    .offerings-grid.grid--4 {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 640px) and (max-width: 959px) {
    .offerings-grid.grid--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
