---
import { t, getLangFromUrl } from '../i18n/index';
import type { Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = getLangFromUrl(Astro.url) } = Astro.props;

const trustItems = [
  {
    title: t('trust.item1.title', lang),
    description: t('trust.item1.desc', lang),
  },
  {
    title: t('trust.item2.title', lang),
    description: t('trust.item2.desc', lang),
  },
  {
    title: t('trust.item3.title', lang),
    description: t('trust.item3.desc', lang),
  },
];
---

<section class="section trust-section" aria-labelledby="trust-heading">
  <div class="container">
    <header class="section-header">
      <span class="eyebrow">{t('trust.eyebrow', lang)}</span>
      <h2 id="trust-heading">{t('trust.title', lang)}</h2>
      <hr class="divider" />
      <p>{t('trust.subtitle', lang)}</p>
    </header>

    <div class="trust-grid">
      {trustItems.map((item, i) => (
        <div class="trust-item">
          <span class="trust-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>

    <blockquote class="trust-quote">
      <p>{t('trust.quote', lang)}</p>
      <footer>{t('trust.quoteAttr', lang)}</footer>
    </blockquote>
  </div>
</section>

<style>
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    max-width: 960px;
    margin: 0 auto var(--space-3xl);
  }

  @media (min-width: 640px) {
    .trust-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .trust-item {
    position: relative;
    padding-top: var(--space-lg);
  }

  .trust-number {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-bg-alt);
    line-height: 1;
    position: absolute;
    top: -8px;
    left: 0;
  }

  .trust-item h3 {
    font-size: 1.15rem;
    margin-bottom: var(--space-sm);
    position: relative;
    z-index: 1;
  }

  .trust-item p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .trust-quote {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .trust-quote p {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0 auto var(--space-md);
  }

  .trust-quote footer {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }
</style>
